# OpenAI API key used only by the backend.
# Copy this file to .env.local when the application is implemented.
OPENAI_API_KEY=

# Optional. Defaults to gpt-5-mini.
OPENAI_MODEL=

# Optional. When true, /api/audit returns a simulated response without calling OpenAI.
NEXODOC_MOCK_MODE=false

# Optional. Mock response delay in milliseconds. Defaults to 3500.
NEXODOC_MOCK_DELAY_MS=3500
