# OpenAI API key used only by the backend.
# Copy this file to .env.local when the application is implemented.
OPENAI_API_KEY=

# Auth.js. Login is available exclusively through Google OAuth.
# Generate AUTH_SECRET once with Node:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Required when serving behind a trusted reverse proxy, such as Render.
AUTH_TRUST_HOST=true
# Comma-separated Google accounts allowed to open /admin/* screens.
NEXODOC_ADMIN_EMAILS=

# Frontend-only. Leave empty for same-origin local development.
# In Vercel, set this to the Render backend URL, for example:
# NEXT_PUBLIC_API_URL=https://nexodoc-api.onrender.com
NEXT_PUBLIC_API_URL=

# Backend-only. Comma-separated origins allowed to call /api/audit.
# In Render, set this to the Vercel production and preview origins.
NEXODOC_ALLOWED_ORIGINS=

# Backend-only. Protects all /api/admin/* endpoints after admin page access is granted.
NEXODOC_ADMIN_TOKEN=

# Backend-only. OpenAI Admin API key used for organization usage/cost endpoints.
OPENAI_ADMIN_KEY=

# Backend-only. PostgreSQL connection URL, recommended Neon Postgres.
DATABASE_URL=

# Optional. Enables the main workspace to read recent persisted audits in production.
# Local development enables this automatically.
NEXODOC_ENABLE_PUBLIC_AUDIT_HISTORY=false

# Backend-only. Used by the post-audit chat and as a legacy fallback for deep audit.
OPENAI_MODEL=gpt-5.4-mini

# Backend-only. OpenAI model used only for stamp extraction in Criador de LDs.
NEXODOC_LD_OPENAI_MODEL=gpt-5.4

# Backend-only. MiMo fallback used only for stamp extraction in Criador de LDs.
# Rotate this value if it has ever been shared outside the backend environment.
MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5

# Backend-only. Legacy fallback for the deep validation model when its explicit override is omitted.
OPENAI_VALIDATION_MODEL=

# Backend-only. OpenAI models used by the main audit flow.
OPENAI_STANDARD_MODEL=gpt-5.4-mini
OPENAI_STANDARD_VALIDATION_MODEL=gpt-5.4-mini
OPENAI_DEEP_MODEL=gpt-5.4
OPENAI_DEEP_VALIDATION_MODEL=gpt-5.4

# Optional. Deep audit throughput controls. Defaults to 24 chunks, 5 parallel chunks.
NEXODOC_MAX_CHUNKS_PER_FILE=24
NEXODOC_CHUNK_CONCURRENCY=5
NEXODOC_CHUNK_TIMEOUT_MS=120000
NEXODOC_DEEP_CHUNK_MAX_OUTPUT_TOKENS=1800

# Optional. When true, /api/audit returns a simulated response without calling OpenAI.
NEXODOC_MOCK_MODE=false

# Optional. Allows users to activate the demo toggle in production. Defaults to false.
NEXODOC_ALLOW_CLIENT_DEMO=false

# Optional. Mock response delay in milliseconds. Defaults to 3500.
NEXODOC_MOCK_DELAY_MS=3500
