# OpenAI API key used only by the backend.
# Copy this file to .env.local when the application is implemented.
OPENAI_API_KEY=

# Frontend-only. Leave empty for same-origin local development.
# In Vercel, set this to the Render backend URL, for example:
# NEXT_PUBLIC_API_URL=https://nexodoc-api.onrender.com
NEXT_PUBLIC_API_URL=

# Backend-only. Comma-separated origins allowed to call /api/audit.
# In Render, set this to the Vercel production and preview origins.
NEXODOC_ALLOWED_ORIGINS=

# Optional. Defaults to gpt-5.4-mini.
OPENAI_MODEL=gpt-5.4-mini

# Optional. Deep audit throughput controls. Defaults to 24 chunks, 5 parallel chunks.
NEXODOC_MAX_CHUNKS_PER_FILE=24
NEXODOC_CHUNK_CONCURRENCY=5
NEXODOC_CHUNK_TIMEOUT_MS=120000
NEXODOC_DEEP_CHUNK_MAX_OUTPUT_TOKENS=1800

# Optional. When true, /api/audit returns a simulated response without calling OpenAI.
NEXODOC_MOCK_MODE=false

# Optional. Mock response delay in milliseconds. Defaults to 3500.
NEXODOC_MOCK_DELAY_MS=3500

# Optional. Output limits by audit type.
NEXODOC_MEMORIAL_MAX_OUTPUT_TOKENS=768
NEXODOC_VOLUME_MAX_OUTPUT_TOKENS=768
