generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum AuditStatus {
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum AuditFeedbackVerdict {
  CONFIRMED
  FALSE_POSITIVE
  WRONG_SEVERITY
  MISSING_FINDING
}

enum LdDraftStatus {
  DRAFT
  GENERATED
  ARCHIVED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  audits       Audit[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Audit {
  id             String       @id @default(cuid())
  userId         String?
  title          String
  projectName    String
  description    String      @default("")
  auditMode      String
  analysisLevel  String      @default("standard")
  status         AuditStatus @default(PROCESSING)
  result         String?
  report         Json?
  error          String?
  elapsedMs      Int?
  totalFindings  Int         @default(0)
  createdAt      DateTime    @default(now())
  completedAt    DateTime?
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  files          AuditFile[]
  feedback       AuditFeedback[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model AuditFeedback {
  id           String               @id @default(cuid())
  auditId      String
  targetKey    String
  findingId    String?
  findingLabel String?
  page         String?
  verdict      AuditFeedbackVerdict
  note         String               @default("")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  audit        Audit                @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, targetKey])
  @@index([auditId, createdAt])
  @@index([verdict, createdAt])
}

model AuditFile {
  id                 String   @id @default(cuid())
  auditId            String
  fileName           String
  documentType       String
  pageCount          Int?
  extractedCharCount Int?
  sizeBytes          Int?
  createdAt          DateTime @default(now())
  audit              Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId])
}

model LdDraft {
  id                 String        @id @default(cuid())
  userEmail          String
  userName           String?
  title              String
  projectCode        String
  workName           String
  status             LdDraftStatus @default(DRAFT)
  activeStep         Int           @default(0)
  ldData             Json
  rows               Json
  tomos              Json
  referenceTotal     Int?
  manualTotal        String        @default("")
  uploadedFileNames  Json
  generatedFileNames Json
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  generatedAt        DateTime?
  events             LdDraftEvent[]

  @@index([userEmail, updatedAt])
  @@index([status, updatedAt])
}

model LdDraftEvent {
  id         String   @id @default(cuid())
  draftId    String
  actorEmail String
  actorName  String?
  action     String
  summary    String
  details    Json?
  createdAt  DateTime @default(now())
  draft      LdDraft  @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId, createdAt])
  @@index([actorEmail, createdAt])
}
